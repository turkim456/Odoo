<odoo>

    <record id="view_hospital_doctor_list" model="ir.ui.view">
        <field name="name">hospital.doctor.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors">
                <field name="name"/>
                <field name="specialty"/>
                <field name="phone"/>
                <field name="patient_count"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_doctor_kanban" model="ir.ui.view">
        <field name="name">hospital.doctor.kanban</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban default_group_by="specialty" class="o_kanban_mobile">
                <field name="name"/>
                <field name="specialty"/>
                <field name="phone"/>
                <field name="patient_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="phone"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    Patients: <field name="patient_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="specialty"/>
                        <field name="phone"/>
                    </group>
                    <notebook>
                        <page string="Assigned Patients">
                            <field name="patient_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="triage_level"/>
                                    <field name="phone"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_doctor" model="ir.actions.act_window">
    <field name="name">Doctors</field>
    <field name="res_model">hospital.doctor</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="view_id" ref="view_hospital_doctor_list"/>
</record>

</odoo>