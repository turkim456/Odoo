<?xml version="1.0" encoding="utf-8"?>
<odoo>

  
    <record id="view_hospital_patient_list" model="ir.ui.view">
        <field name="name">hospital.patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list string="Patients">
                <field name="name"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="blood_group"/>
                <field name="triage_level"
                decoration-danger="triage_level == 'critical'"
                decoration-warning="triage_level == 'observation_unit'"
                decoration-success="triage_level == 'general_ward'"
                decoration-info="triage_level == 'opd'"/>
                <field name="doctor_id"/>
            </list>
        </field>
    </record>


    <record id="view_hospital_patient_kanban" model="ir.ui.view">
        <field name="name">hospital.patient.kanban</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <kanban default_group_by="triage_level">

                <field name="name"/>
                <field name="file_number"/>
                <field name="triage_level"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">

                            <div>
                                   <span>Name:</span>
                                    <field name="name"/>
                             
                            </div>

                            <div>
                                <span>File No:</span>
                                <field name="file_number"/>
                            </div>

                            <div>
                             <span>Triage:</span>

                            <t t-if="record.triage_level.raw_value == 'critical'">
                            <span style="color:red; font-weight:bold;">
                             Critical
                            </span>
                            </t>

                            <t t-if="record.triage_level.raw_value == 'observation_unit'">
                             <span style="color:orange; font-weight:bold;">
                                Observation Unit
                             </span>
                            </t>

                            <t t-if="record.triage_level.raw_value == 'general_ward'">
                            <span style="color:green; font-weight:bold;">
                            General Ward
                            </span>
                            </t>

                            <t t-if="record.triage_level.raw_value == 'opd'">
                            <span style="color:blue; font-weight:bold;">
                            Outpatient Department (OPD)
                            </span>
                            </t>

                </div>

                        </div>
                    </t>
                </templates>

            </kanban>
        </field>
    </record>


    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="blood_group"/>
                        </group>

                        <group>
                            <field name="phone"/>
                            <field name="file_number"/>
                            <field name="id_number"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="triage_level"/>
                        </group>

                        <group>
                            <field name="doctor_id"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Medical Records">

                            <field name="medical_record_ids">

                                <list editable="bottom">
                                    <field name="diagnosis"/>
                                    <field name="doctor_notes"/>
                                    <field name="visit_date"/>
                                    

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    
    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>